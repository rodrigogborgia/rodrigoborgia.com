{
  "name": "rb-strategic-framework-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20 <22"
  },
  "scripts": {
    "dev": "vite",
    "prebuild": "node scripts/generate-seo-assets.mjs",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "seo:generate": "node scripts/generate-seo-assets.mjs",
    "test": "jest --runInBand",
    "test:ci": "jest --ci --coverage --runInBand",
    "test:unit:ci": "jest --ci --coverage --runInBand --testPathIgnorePatterns=src/__tests__/integration"
  },
  "dependencies": {
    "@babel/core": "^7.29.0",
    "babel-jest": "^30.3.0",
    "identity-obj-proxy": "^3.0.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-helmet-async": "^3.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.11",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.2",
    "cross-fetch": "^4.1.0",
    "jest": "^30.1.3",
    "jest-environment-jsdom": "^30.1.2",
    "sharp": "^0.34.4",
    "ts-jest": "^29.4.1",
    "typescript": "^5.9.2",
    "vite": "^7.1.3"
  }
}
