
# Opcional: ruta externa de secrets fuera del repo (ej: ~/.rb-secrets/backend.env)
RB_ENV_FILE=

JWT_SECRET_KEY=change_this_in_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=720
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174,http://localhost:4173,http://127.0.0.1:4173,http://localhost:4174,http://127.0.0.1:4174

# Brevo CRM Integration
# Obtén tu API key en https://my.brevo.com/settings/account/api
BREVO_API_KEY=your_brevo_api_key_here
# ID de la lista de contactos (default: 3 - Cómo usar IA para preparar nuestras negociaciones)
BREVO_LIST_ID=3
# Atributo personalizado para guardar la preocupación/fuente del lead
BREVO_INTEREST_ATTRIBUTE=PREOCUPACION_NEGOCIACION
BREVO_SOURCE_ATTRIBUTE=LEAD_SOURCE